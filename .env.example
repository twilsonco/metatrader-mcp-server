# MetaTrader 5 MCP Server Credentials Example
LOGIN=your_login_here
PASSWORD=your_password_here
SERVER=your_server_here

# Optional: Path to MT5 terminal executable (auto-detected if not specified)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# MCP Transport Configuration
# MCP_TRANSPORT=sse
# MCP_HOST=0.0.0.0
# MCP_PORT=8080

# WebSocket Quote Server Configuration
# QUOTE_HOST=0.0.0.0
# QUOTE_PORT=8765
# QUOTE_SYMBOLS=XAUUSD,USOIL,GBPUSD,USDJPY,EURUSD,BTCUSD
# QUOTE_POLL_INTERVAL_MS=100

# Logging Configuration
# LOG_LEVEL controls verbosity for all MT5* loggers (MT5Connection, MT5Account,
# MT5History, MT5Market, MT5Order). Accepted values: DEBUG, INFO, WARNING, ERROR.
# Default: INFO
# LOG_LEVEL=DEBUG

# MT5_DEBUG enables verbose connection-level logging inside the MT5 client
# (retry attempts, cooldown delays, terminal init steps). Accepts: 1/true/yes.
# Default: false
# MT5_DEBUG=true